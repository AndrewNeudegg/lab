{
  "name": "@homelab/dashboard",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "browser:preflight": "bun scripts/browser-preflight.mjs",
    "playwright:install": "playwright install chromium",
    "uat:chat-markdown": "bun scripts/chat-markdown-uat.mjs",
    "uat:docs": "bun run playwright:install && bun run browser:preflight && playwright test e2e/docs-library.spec.ts",
    "uat:tasks": "bun run playwright:install && bun run browser:preflight && playwright test e2e/chat-tasks-mobile.spec.ts",
    "uat:site": "bun run playwright:install && bun run browser:preflight && playwright test e2e",
    "uat:tasks:live": "bun scripts/tasks-page-uat.mjs",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "e2e": "bun run uat:site"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@homelab/shared": "workspace:*",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0"
  }
}
