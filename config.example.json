{
  "agent_name": "homelab-lead",
  "default_provider": "gemini",
  "providers": {
    "gemini": {
      "type": "gemini",
      "base_url": "https://generativelanguage.googleapis.com/v1beta",
      "model": "gemini-flash-latest",
      "api_key_env": "GEMINI_API_KEY"
    },
    "openai": {
      "type": "openai-compatible",
      "base_url": "https://api.openai.com/v1",
      "model": "gpt-5.1",
      "api_key_env": "OPENAI_API_KEY"
    },
    "ollama": {
      "type": "openai-compatible",
      "base_url": "http://localhost:11434/v1",
      "model": "qwen3-coder"
    }
  },
  "repo": {
    "root": "/srv/homelab/mono",
    "workspace_root": "/srv/homelab/workspaces"
  },
  "policy": {
    "require_approval_for": [
      "shell.run_approved",
      "service.restart",
      "llm.switch_provider",
      "git.commit",
      "repo.apply_patch_to_main",
      "git.merge_approved"
    ]
  },
  "limits": {
    "max_concurrent_tasks": 4,
    "max_tool_calls_per_turn": 12,
    "max_shell_seconds": 60,
    "max_file_bytes": 1048576
  },
  "data_dir": "data",
  "http": {
    "addr": "127.0.0.1:18080"
  },
  "healthd": {
    "enabled": true,
    "sample_interval_seconds": 5,
    "retention_seconds": 300,
    "request_timeout_seconds": 2,
    "checks": [
      {
        "name": "homelabd-api",
        "type": "http",
        "url": "http://127.0.0.1:18080/events",
        "method": "GET"
      }
    ],
    "slos": [
      {
        "name": "availability",
        "target_percent": 99.9,
        "window_seconds": 300,
        "warning_burn_rate": 2,
        "page_burn_rate": 10
      }
    ],
    "notifications": [
      {
        "name": "oncall-webhook",
        "type": "webhook",
        "url": "http://127.0.0.1:19090/healthd",
        "min_severity": "warn"
      }
    ]
  },
  "matrix": {
    "homeserver": "http://lab:8008",
    "user": "${ELEMENT_BOT_USERNAME}",
    "password": "${ELEMENT_BOT_PASSWORD}",
    "room_name": "first",
    "require_prefix": true,
    "prefix": "!agent",
    "sync_timeout_ms": 30000
  },
  "external_agents": {
    "codex": {
      "enabled": true,
      "command": "codex",
      "args": ["exec", "--skip-git-repo-check"],
      "timeout_seconds": 900,
      "description": "OpenAI Codex CLI worker for coding tasks."
    },
    "claude": {
      "enabled": true,
      "command": "claude",
      "args": [],
      "timeout_seconds": 900,
      "description": "Claude CLI worker for analysis or coding tasks."
    },
    "gemini": {
      "enabled": true,
      "command": "gemini",
      "args": [],
      "timeout_seconds": 900,
      "description": "Gemini CLI worker for analysis or coding tasks."
    }
  }
}
