{
  "name": "homelab-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "dashboard"
  ],
  "scripts": {
    "dev": "bun run --cwd dashboard dev",
    "build": "bun run --cwd dashboard build",
    "check": "bun run --cwd shared check && bun run --cwd dashboard check",
    "test": "bun test shared/src/lib dashboard/src/routes dashboard/src/lib dashboard/scripts",
    "uat:docs": "bun run --cwd dashboard uat:docs",
    "uat:tasks": "bun run --cwd dashboard uat:tasks",
    "e2e": "bun run --cwd dashboard e2e"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
